// ============================================================================
// SCORING ENGINE — SHARED
// ============================================================================
const sH = (v, t) => { if (v==null||isNaN(v)) return null; if(v>=t[0])return 95;if(v>=t[1])return 85;if(v>=t[2])return 72;if(v>=t[3])return 58;if(v>=t[4])return 45;return 25; };
const sL = (v, t) => { if (v==null||isNaN(v)) return null; if(v<=t[0])return 95;if(v<=t[1])return 85;if(v<=t[2])return 72;if(v<=t[3])return 58;if(v<=t[4])return 45;return 25; };
const s2g = s => { if(s===null)return'N/A';if(s>=93)return'A+';if(s>=88)return'A';if(s>=83)return'A-';if(s>=78)return'B+';if(s>=73)return'B';if(s>=68)return'B-';if(s>=63)return'C+';if(s>=58)return'C';if(s>=53)return'C-';if(s>=48)return'D+';if(s>=43)return'D';if(s>=38)return'D-';return'F'; };
const gC = g => { if(g==='N/A')return'#6b6760';const l=g[0];if(l==='A')return'#4ade80';if(l==='B')return'#86c26a';if(l==='C')return'#e0a94e';if(l==='D')return'#f08a5d';return'#ef4444'; };
const avg = a => { const v=a.filter(x=>x!=null&&!isNaN(x));return v.length?v.reduce((a,b)=>a+b,0)/v.length:null; };
const cR = s => { if(s===null)return{label:'NO DATA',color:'#6b6760'};if(s>=80)return{label:'STRONG BUY',color:'#22c55e'};if(s>=65)return{label:'BUY',color:'#86c26a'};if(s>=45)return{label:'HOLD',color:'#e0a94e'};if(s>=30)return{label:'SELL',color:'#f08a5d'};return{label:'STRONG SELL',color:'#ef4444'}; };

