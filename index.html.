    })();
  },[]);

  const loadIdeas = async (force=false)=>{
    if(!force){const c=await load('market_ideas');if(c&&(Date.now()-c.timestamp)/(1e3*3600)<24){setMi(c.ideas);setMiTs(c.timestamp);return;}}
    setMiL(true);setMiE(null);
    try{const ideas=await fetchMarketIdeas();const ts=Date.now();setMi(ideas);setMiTs(ts);await save('market_ideas',{ideas,timestamp:ts});}catch(e){setMiE(e.message||'Failed');}finally{setMiL(false);}
  };

  const saveRecent = async (result,grades,isEtf)=>{
    const entry={ticker:result.ticker||result.ticker,name:isEtf?result.fundName:result.companyName,price:result.price,priceChangePercent:result.priceChangePercent,compositeGrade:grades.composite.grade,ratingLabel:grades.composite.rating.label,ratingColor:grades.composite.rating.color,isEtf,timestamp:Date.now()};
    const existing=(await load('recent_analyses'))||[];
    const updated=[entry,...existing.filter(e=>e.ticker!==entry.ticker)].slice(0,20);
    setRecent(updated);await save('recent_analyses',updated);
  };

  const clearRecent = async ()=>{setRecent([]);await save('recent_analyses',[]);};

  const run = async (sym)=>{
    const t=sym.toUpperCase().trim();if(!t)return;
    setTicker(t);setInput(t);setLoading(true);setError(null);setData(null);setAf(null);
    try{
      const result=await detectAndFetch(t);
      setData(result);
      const isEtf=result.assetType==='ETF';
      const g=isEtf?computeEtfGrades(result):computeStockGrades(result);
      if(g)await saveRecent(result,g,isEtf);
    }catch(e){setError(e.message||'Failed to fetch data');}finally{setLoading(false);}
  };

  const isEtf=data?.assetType==='ETF';
  const grades=data?(isEtf?computeEtfGrades(data):computeStockGrades(data)):null;
  const fmtAge=ts=>{if(!ts)return'';const m=Math.floor((Date.now()-ts)/(6e4));if(m<60)return`${m}m ago`;const h=Math.floor(m/60);if(h<24)return`${h}h ago`;return`${Math.floor(h/24)}d ago`;};
  const filteredIdeas=mi?.filter(i=>{if(miF==='all')return true;if(miF==='stocks')return i.type==='Stock';if(miF==='etfs')return i.type==='ETF';if(miF==='long')return i.direction==='Long';if(miF==='short')return i.direction==='Short';return true;});

  // ETF factor config
  const etfFactors=[
    {key:'cost',icon:Percent,title:'Cost & Structure',desc:'Expense ratio, AUM, liquidity',count:4},
    {key:'performance',icon:TrendingUp,title:'Performance',desc:'Returns vs benchmark',count:5},
    {key:'risk',icon:Shield,title:'Risk',desc:'Sharpe, drawdown, volatility',count:5},
    {key:'income',icon:DollarSign,title:'Income',desc:'Yield, distribution growth',count:4},
    {key:'holdings',icon:Layers,title:'Holdings Quality',desc:'Weighted fundamentals',count:5},
  ];
