const detectAndFetch = async (ticker) => {
  // First do a quick detection call
  const detectPrompt = `Is the ticker "${ticker.toUpperCase()}" a Stock or an ETF/Fund? Use web search if unsure. Respond with ONLY the word "Stock" or "ETF" and nothing else.`;
  const dr = await fetch("https://api.anthropic.com/v1/messages",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:50,tools:[{type:"web_search_20250305",name:"web_search"}],messages:[{role:"user",content:detectPrompt}]})});
  if(!dr.ok) throw new Error(`Detection API error: ${dr.status}`);
  const dRes = await dr.json();
  const dText = dRes.content.filter(b=>b.type==="text").map(b=>b.text).join("").trim().toUpperCase();
  const isEtf = dText.includes("ETF");
  if(isEtf) return await fetchEtfData(ticker);
  return await fetchStockData(ticker);
};

