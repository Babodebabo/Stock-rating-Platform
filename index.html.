            <div className="flex flex-wrap gap-2">{recent.map(r=><button key={r.ticker} onClick={()=>run(r.ticker)} className="flex items-center gap-2 px-3 py-1.5 bg-stone-900 hover:bg-stone-800 border border-stone-800 rounded text-xs transition" style={{fontFamily:'JetBrains Mono,monospace'}}><span className="font-bold text-stone-200">{r.ticker}</span>{r.isEtf&&<span className="text-stone-600 text-[10px]">ETF</span>}<span className="px-1.5 rounded font-bold" style={{background:`${r.ratingColor}20`,color:r.ratingColor}}>{r.compositeGrade}</span><span className="text-stone-500">{fmtAge(r.timestamp)}</span></button>)}</div>
          </div>
