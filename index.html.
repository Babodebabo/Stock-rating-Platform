  const [af,setAf]=useState(null);
  const [showMeth,setShowMeth]=useState(false);
  const [mi,setMi]=useState(null);
  const [miL,setMiL]=useState(false);
  const [miE,setMiE]=useState(null);
  const [miTs,setMiTs]=useState(null);
  const [miF,setMiF]=useState('all');
  const [recent,setRecent]=useState([]);

  useEffect(()=>{
