const computeStockGrades = d => {
  if(!d) return null;
  const vs=[sL(d.valuation?.peTrailing,[12,18,25,35,50]),sL(d.valuation?.peForward,[11,16,22,30,45]),sL(d.valuation?.pegRatio,[0.8,1.2,1.8,2.5,3.5]),sL(d.valuation?.psRatio,[1.5,3,5,8,12]),sL(d.valuation?.pbRatio,[1.5,3,5,8,12]),sL(d.valuation?.evEbitda,[8,12,16,22,30]),sL(d.valuation?.pFcf,[12,18,25,35,50])];
  const gs=[sH(d.growth?.revenueGrowthYoY,[25,15,10,5,2]),sH(d.growth?.revenueGrowth3YAvg,[22,14,9,5,2]),sH(d.growth?.revenueGrowth5YAvg,[20,13,8,4,1]),sH(d.growth?.epsGrowthYoY,[30,18,12,6,2]),sH(d.growth?.epsGrowthForward,[25,15,10,5,2]),sH(d.growth?.fcfGrowthYoY,[25,15,10,5,2]),sH(d.growth?.ebitdaGrowthYoY,[25,15,10,5,2])];
  const ps=[sH(d.profitability?.grossMargin,[55,42,32,22,12]),sH(d.profitability?.operatingMargin,[25,17,12,7,2]),sH(d.profitability?.netMargin,[20,14,9,5,1]),sH(d.profitability?.roe,[25,17,12,7,3]),sH(d.profitability?.roa,[15,9,6,3,1]),sH(d.profitability?.roic,[20,13,9,5,2]),sH(d.profitability?.fcfMargin,[20,13,8,4,1])];
  const m=d.momentum||{};const rel=(m.return1Y!=null&&m.sp500Return1Y!=null)?m.return1Y-m.sp500Return1Y:null;
  const ms=[sH(m.return3M,[18,10,4,0,-5]),sH(m.return6M,[28,15,8,0,-10]),sH(m.return9M,[40,22,10,0,-12]),sH(m.return1Y,[45,25,12,0,-15]),sH(rel,[20,10,3,-5,-15])];
  const r=d.revisions||{};const rr=(r.upwardRevisions90d+r.downwardRevisions90d>0)?r.upwardRevisions90d/(r.upwardRevisions90d+r.downwardRevisions90d):null;
  const rs=[sH(rr,[0.85,0.70,0.55,0.45,0.30]),sH(r.fy1EpsRevisionPercent,[4,2,0.5,-1,-3]),sH(r.fy2EpsRevisionPercent,[4,2,0.5,-1,-3])];
  const vS=avg(vs),gS=avg(gs),pS=avg(ps),mS=avg(ms),rS=avg(rs);
  const comp=avg([vS,gS,pS,mS,rS]);
  return{valuation:{score:vS,grade:s2g(vS),ms:vs},growth:{score:gS,grade:s2g(gS),ms:gs},profitability:{score:pS,grade:s2g(pS),ms:ps},momentum:{score:mS,grade:s2g(mS),ms:ms},revisions:{score:rS,grade:s2g(rS),ms:rs},composite:{score:comp,grade:s2g(comp),rating:cR(comp)}};
};

