                <h3 className="text-xl font-bold mb-1">Income Analysis</h3>
                <p className="text-xs text-stone-500 mb-4">Distribution yield quality and growth trajectory.</p>
                <MR label="Distribution Yield" value={data.income?.distributionYield} unit="%" score={grades.income?.ms[0]}/>
                <MR label="Yield Growth (3Y)" value={data.income?.yieldGrowth3Y} unit="%" score={grades.income?.ms[1]}/>
                <MR label="Yield Growth (5Y)" value={data.income?.yieldGrowth5Y} unit="%" score={grades.income?.ms[2]}/>
                <MR label="Yield Volatility (CV)" value={data.income?.yieldVolatility} unit="%" score={grades.income?.ms[3]}/>
                <div className="mt-4 pt-3 border-t border-stone-800 grid grid-cols-3 gap-4 text-xs" style={{fontFamily:'JetBrains Mono,monospace'}}>
                  <div><span className="text-stone-500">SEC Yield </span><span className="text-stone-200">{data.income?.secYield?.toFixed(2)||'N/A'}%</span></div>
                  <div><span className="text-stone-500">Frequency </span><span className="text-stone-200">{data.income?.distributionFrequency||'N/A'}</span></div>
                  <div><span className="text-stone-500">Last Dist </span><span className="text-stone-200">${data.income?.lastDistribution?.toFixed(4)||'N/A'}</span></div>
                </div>
              </div>
            )}

            {isEtf&&af==='holdings'&&(
              <div className="bg-stone-900/50 border border-stone-800 rounded-lg p-6">
                <h3 className="text-xl font-bold mb-1">Holdings Quality</h3>
                <p className="text-xs text-stone-500 mb-4">Weighted-average fundamentals and portfolio concentration.</p>
                <MR label="Wtd ROE" value={data.holdings?.wtdRoe} unit="%" score={grades.holdings?.ms[0]}/>
                <MR label="Wtd ROIC" value={data.holdings?.wtdRoic} unit="%" score={grades.holdings?.ms[1]}/>
                <MR label="Wtd FCF Margin" value={data.holdings?.wtdFcfMargin} unit="%" score={grades.holdings?.ms[2]}/>
                <MR label="Top 10 Concentration" value={data.holdings?.concentration} unit="%" score={grades.holdings?.ms[3]}/>
                <MR label="Number of Holdings" value={data.holdings?.numHoldings} score={grades.holdings?.ms[4]}/>
                {data.holdings?.wtdPe&&<div className="mt-3 grid grid-cols-2 gap-4 text-xs" style={{fontFamily:'JetBrains Mono,monospace'}}><div><span className="text-stone-500">Wtd P/E </span><span className="text-stone-200">{data.holdings.wtdPe?.toFixed(1)}</span></div><div><span className="text-stone-500">Wtd P/B </span><span className="text-stone-200">{data.holdings.wtdPb?.toFixed(1)}</span></div><div><span className="text-stone-500">Turnover </span><span className="text-stone-200">{data.holdings.turnover?.toFixed(0)||'N/A'}%</span></div></div>}

                {data.holdings?.topHoldings?.length>0&&(
                  <div className="mt-5 pt-4 border-t border-stone-800">
                    <div className="text-xs uppercase tracking-widest text-stone-500 mb-3" style={{fontFamily:'JetBrains Mono,monospace'}}>Top Holdings</div>
                    <div className="space-y-1">{data.holdings.topHoldings.map((h,i)=>(
                      <div key={i} className="flex items-center justify-between py-1.5 text-xs">
                        <div className="flex items-center gap-2"><span className="text-stone-600 w-5" style={{fontFamily:'JetBrains Mono,monospace'}}>{i+1}</span><span className="text-stone-200 font-bold" style={{fontFamily:'JetBrains Mono,monospace'}}>{h.ticker||''}</span><span className="text-stone-400 truncate max-w-[200px]">{h.name}</span></div>
                        <span className="text-stone-300" style={{fontFamily:'JetBrains Mono,monospace'}}>{h.weight?.toFixed(2)}%</span>
                      </div>
                    ))}</div>
                  </div>
                )}

                {data.holdings?.sectorBreakdown?.length>0&&(
                  <div className="mt-5 pt-4 border-t border-stone-800">
                    <div className="text-xs uppercase tracking-widest text-stone-500 mb-3" style={{fontFamily:'JetBrains Mono,monospace'}}>Sector Allocation</div>
                    <SectorBar sectors={data.holdings.sectorBreakdown}/>
                  </div>
                )}
              </div>
            )}

            {/* ========== STOCK FACTOR DETAILS ========== */}
            {!isEtf&&af==='valuation'&&(
              <div className="bg-stone-900/50 border border-stone-800 rounded-lg p-6">
                <h3 className="text-xl font-bold mb-1">Valuation Breakdown</h3><p className="text-xs text-stone-500 mb-4">Lower multiples score better.</p>
                <MR label="P/E (Trailing)" value={data.valuation?.peTrailing} score={grades.valuation?.ms[0]} benchmark={data.valuation?.sectorPe}/><MR label="P/E (Forward)" value={data.valuation?.peForward} score={grades.valuation?.ms[1]}/><MR label="PEG Ratio" value={data.valuation?.pegRatio} score={grades.valuation?.ms[2]}/><MR label="Price / Sales" value={data.valuation?.psRatio} score={grades.valuation?.ms[3]} benchmark={data.valuation?.sectorPs}/><MR label="Price / Book" value={data.valuation?.pbRatio} score={grades.valuation?.ms[4]}/><MR label="EV / EBITDA" value={data.valuation?.evEbitda} score={grades.valuation?.ms[5]}/><MR label="Price / FCF" value={data.valuation?.pFcf} score={grades.valuation?.ms[6]}/>
              </div>
            )}
            {!isEtf&&af==='growth'&&(
              <div className="bg-stone-900/50 border border-stone-800 rounded-lg p-6">
                <h3 className="text-xl font-bold mb-1">Growth Breakdown</h3><p className="text-xs text-stone-500 mb-4">All figures annualized where applicable.</p>
                <MR label="Revenue Growth YoY" value={data.growth?.revenueGrowthYoY} unit="%" score={grades.growth?.ms[0]}/><MR label="Revenue 3yr CAGR" value={data.growth?.revenueGrowth3YAvg} unit="%" score={grades.growth?.ms[1]}/><MR label="Revenue 5yr CAGR" value={data.growth?.revenueGrowth5YAvg} unit="%" score={grades.growth?.ms[2]}/><MR label="EPS Growth YoY" value={data.growth?.epsGrowthYoY} unit="%" score={grades.growth?.ms[3]}/><MR label="EPS Growth (Forward)" value={data.growth?.epsGrowthForward} unit="%" score={grades.growth?.ms[4]}/><MR label="FCF Growth YoY" value={data.growth?.fcfGrowthYoY} unit="%" score={grades.growth?.ms[5]}/><MR label="EBITDA Growth YoY" value={data.growth?.ebitdaGrowthYoY} unit="%" score={grades.growth?.ms[6]}/>
              </div>
            )}
            {!isEtf&&af==='profitability'&&(
              <div className="bg-stone-900/50 border border-stone-800 rounded-lg p-6">
                <h3 className="text-xl font-bold mb-1">Profitability Breakdown</h3><p className="text-xs text-stone-500 mb-4">Margins show pricing power. Returns on capital show efficiency.</p>
                <MR label="Gross Margin" value={data.profitability?.grossMargin} unit="%" score={grades.profitability?.ms[0]}/><MR label="Operating Margin" value={data.profitability?.operatingMargin} unit="%" score={grades.profitability?.ms[1]}/><MR label="Net Margin" value={data.profitability?.netMargin} unit="%" score={grades.profitability?.ms[2]}/><MR label="Return on Equity" value={data.profitability?.roe} unit="%" score={grades.profitability?.ms[3]}/><MR label="Return on Assets" value={data.profitability?.roa} unit="%" score={grades.profitability?.ms[4]}/><MR label="Return on Invested Capital" value={data.profitability?.roic} unit="%" score={grades.profitability?.ms[5]}/><MR label="FCF Margin" value={data.profitability?.fcfMargin} unit="%" score={grades.profitability?.ms[6]}/>
              </div>
            )}
            {!isEtf&&af==='momentum'&&(
              <div className="bg-stone-900/50 border border-stone-800 rounded-lg p-6">
                <h3 className="text-xl font-bold mb-1">Momentum Breakdown</h3><p className="text-xs text-stone-500 mb-4">Absolute and relative price performance.</p>
                <MR label="1 Month Return" value={data.momentum?.return1M} unit="%"/><MR label="3 Month Return" value={data.momentum?.return3M} unit="%" score={grades.momentum?.ms[0]}/><MR label="6 Month Return" value={data.momentum?.return6M} unit="%" score={grades.momentum?.ms[1]}/><MR label="9 Month Return" value={data.momentum?.return9M} unit="%" score={grades.momentum?.ms[2]}/><MR label="1 Year Return" value={data.momentum?.return1Y} unit="%" score={grades.momentum?.ms[3]}/><MR label="YTD Return" value={data.momentum?.returnYTD} unit="%"/><MR label="1Y vs S&P 500" value={data.momentum?.return1Y!=null&&data.momentum?.sp500Return1Y!=null?data.momentum.return1Y-data.momentum.sp500Return1Y:null} unit="%" score={grades.momentum?.ms[4]} highlight/>
              </div>
            )}
            {!isEtf&&af==='revisions'&&(
              <div className="bg-stone-900/50 border border-stone-800 rounded-lg p-6">
                <h3 className="text-xl font-bold mb-1">EPS Revisions</h3><p className="text-xs text-stone-500 mb-4">Analyst estimate changes in the last 90 days.</p>
                <div className="grid grid-cols-2 gap-4 mb-4"><div className="bg-green-950/30 border border-green-900/50 rounded p-4"><div className="text-xs uppercase tracking-widest text-green-400 mb-1" style={{fontFamily:'JetBrains Mono,monospace'}}>Upward</div><div className="text-3xl font-bold text-green-300" style={{fontFamily:'Fraunces,serif'}}>{data.revisions?.upwardRevisions90d}</div></div><div className="bg-red-950/30 border border-red-900/50 rounded p-4"><div className="text-xs uppercase tracking-widest text-red-400 mb-1" style={{fontFamily:'JetBrains Mono,monospace'}}>Downward</div><div className="text-3xl font-bold text-red-300" style={{fontFamily:'Fraunces,serif'}}>{data.revisions?.downwardRevisions90d}</div></div></div>
                <MR label="FY1 EPS Change (90d)" value={data.revisions?.fy1EpsRevisionPercent} unit="%" score={grades.revisions?.ms[1]}/><MR label="FY2 EPS Change (90d)" value={data.revisions?.fy2EpsRevisionPercent} unit="%" score={grades.revisions?.ms[2]}/>
              </div>
            )}

            {/* STOCK DIVIDEND */}
            {!isEtf&&data.dividend&&data.dividend.yield>0&&(
              <div className="bg-gradient-to-br from-amber-950/20 to-stone-950 border border-amber-900/30 rounded-lg p-6">
                <div className="flex items-center gap-2 mb-4"><DollarSign size={20} className="text-amber-400"/><h3 className="text-xl font-bold">Income Analysis</h3></div>
                <div className="grid md:grid-cols-4 gap-4 mb-4">
                  <div className="bg-stone-900/50 rounded p-4"><div className="text-xs uppercase tracking-widest text-stone-500 mb-1" style={{fontFamily:'JetBrains Mono,monospace'}}>Yield</div><div className="text-2xl font-bold text-amber-400" style={{fontFamily:'Fraunces,serif'}}>{data.dividend.yield?.toFixed(2)}%</div></div>
                  <div className="bg-stone-900/50 rounded p-4"><div className="text-xs uppercase tracking-widest text-stone-500 mb-1" style={{fontFamily:'JetBrains Mono,monospace'}}>Annual Div</div><div className="text-2xl font-bold" style={{fontFamily:'Fraunces,serif'}}>${data.dividend.annualDividend?.toFixed(2)}</div></div>
                  <div className="bg-stone-900/50 rounded p-4"><div className="text-xs uppercase tracking-widest text-stone-500 mb-1" style={{fontFamily:'JetBrains Mono,monospace'}}>Payout Ratio</div><div className="text-2xl font-bold" style={{fontFamily:'Fraunces,serif'}}>{data.dividend.payoutRatio?.toFixed(0)}%</div></div>
                  <div className="bg-stone-900/50 rounded p-4"><div className="text-xs uppercase tracking-widest text-stone-500 mb-1" style={{fontFamily:'JetBrains Mono,monospace'}}>Growth Streak</div><div className="text-2xl font-bold" style={{fontFamily:'Fraunces,serif'}}>{data.dividend.consecutiveYearsGrowth||0}y</div></div>
                </div>
              </div>
            )}

            {/* ANALYST CONSENSUS (stocks only) */}
            {!isEtf&&data.analyst&&(
              <div className="bg-stone-900/50 border border-stone-800 rounded-lg p-6">
                <h3 className="text-xl font-bold mb-4">Wall Street Consensus</h3>
                <div className="grid md:grid-cols-3 gap-6 mb-6">
                  <div><div className="text-xs uppercase tracking-widest text-stone-500 mb-1" style={{fontFamily:'JetBrains Mono,monospace'}}>Consensus</div><div className="text-2xl font-bold" style={{fontFamily:'Fraunces,serif',color:data.analyst.consensus?.includes('Buy')?'#86c26a':data.analyst.consensus?.includes('Sell')?'#ef4444':'#e0a94e'}}>{data.analyst.consensus}</div><div className="text-xs text-stone-500 mt-1" style={{fontFamily:'JetBrains Mono,monospace'}}>{data.analyst.numAnalysts} analysts</div></div>
                  <div><div className="text-xs uppercase tracking-widest text-stone-500 mb-1" style={{fontFamily:'JetBrains Mono,monospace'}}>Price Target</div><div className="text-2xl font-bold" style={{fontFamily:'JetBrains Mono,monospace'}}>${data.analyst.priceTarget?.toFixed(2)}</div><div className={`text-xs mt-1 ${(data.analyst.priceTarget-data.price)>0?'text-green-400':'text-red-400'}`} style={{fontFamily:'JetBrains Mono,monospace'}}>{(((data.analyst.priceTarget-data.price)/data.price)*100).toFixed(1)}% upside</div></div>
                  <div><div className="text-xs uppercase tracking-widest text-stone-500 mb-1" style={{fontFamily:'JetBrains Mono,monospace'}}>Target Range</div><div className="text-sm" style={{fontFamily:'JetBrains Mono,monospace'}}><span className="text-red-400">${data.analyst.priceTargetLow?.toFixed(2)}</span><span className="text-stone-500 mx-2">to</span><span className="text-green-400">${data.analyst.priceTargetHigh?.toFixed(2)}</span></div></div>
                </div>
                <AnalystBar analyst={data.analyst}/>
              </div>
            )}

            {/* COMPETITOR ETFs */}
            {isEtf&&data.competitorETFs?.length>0&&(
              <div className="bg-stone-900/30 border border-stone-800 rounded-lg p-5">
                <div className="text-xs uppercase tracking-widest text-stone-500 mb-3" style={{fontFamily:'JetBrains Mono,monospace'}}>Similar ETFs</div>
                <div className="flex flex-wrap gap-2">{data.competitorETFs.map(t=><button key={t} onClick={()=>run(t)} className="px-4 py-2 text-xs bg-stone-900 hover:bg-stone-800 border border-stone-800 rounded transition font-bold" style={{fontFamily:'JetBrains Mono,monospace'}}>{t}</button>)}</div>
              </div>
            )}

            {/* STRENGTHS & RISKS */}
            <div className="grid md:grid-cols-2 gap-4">
              <div className="bg-green-950/20 border border-green-900/30 rounded-lg p-6">
                <div className="flex items-center gap-2 mb-4"><Shield size={18} className="text-green-400"/><h3 className="text-lg font-bold text-green-300">Strengths</h3></div>
                <ul className="space-y-2">{data.strengths?.map((s,i)=><li key={i} className="text-sm text-stone-300 pl-4 relative"><span className="absolute left-0 text-green-400">▸</span>{s}</li>)}</ul>
              </div>
              <div className="bg-red-950/20 border border-red-900/30 rounded-lg p-6">
                <div className="flex items-center gap-2 mb-4"><AlertTriangle size={18} className="text-red-400"/><h3 className="text-lg font-bold text-red-300">Risks</h3></div>
                <ul className="space-y-2">{data.risks?.map((r,i)=><li key={i} className="text-sm text-stone-300 pl-4 relative"><span className="absolute left-0 text-red-400">▸</span>{r}</li>)}</ul>
              </div>
            </div>

            {/* STOCK KEY METRICS */}
            {!isEtf&&data.keyMetrics&&(
              <div className="bg-stone-900/30 border border-stone-800 rounded-lg p-5">
                <div className="text-xs uppercase tracking-widest text-stone-500 mb-3" style={{fontFamily:'JetBrains Mono,monospace'}}>Balance Sheet & Ownership</div>
                <div className="grid md:grid-cols-5 gap-4 text-sm" style={{fontFamily:'JetBrains Mono,monospace'}}>
                  <div><span className="text-stone-500">D/E </span><span className="text-stone-200">{data.keyMetrics.debtToEquity?.toFixed(2)??'N/A'}</span></div>
                  <div><span className="text-stone-500">Current </span><span className="text-stone-200">{data.keyMetrics.currentRatio?.toFixed(2)??'N/A'}</span></div>
                  <div><span className="text-stone-500">Short Int </span><span className="text-stone-200">{data.keyMetrics.shortInterestPercent?.toFixed(1)??'N/A'}%</span></div>
                  <div><span className="text-stone-500">Inst Own </span><span className="text-stone-200">{data.keyMetrics.institutionalOwnership?.toFixed(1)??'N/A'}%</span></div>
                  <div><span className="text-stone-500">Insider </span><span className="text-stone-200">{data.keyMetrics.insiderOwnership?.toFixed(2)??'N/A'}%</span></div>
                </div>
              </div>
            )}

            <div className="text-center text-xs text-stone-600 py-4" style={{fontFamily:'JetBrains Mono,monospace'}}>Data sourced via live web search. Not investment advice. Verify numbers before trading.</div>
          </div>
        )}

        {!data&&!loading&&!error&&(
          <div className="text-center py-12 text-stone-500"><BarChart3 size={40} className="mx-auto mb-3 opacity-30"/><div className="text-sm">Enter any stock or ETF ticker to generate a quant rating</div></div>
        )}
      </main>
    </div>
  );
};

export default App;
