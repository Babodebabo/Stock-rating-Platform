const MR = ({label,value,unit='',score,benchmark,highlight}) => {
  const grade=score!=null?s2g(score):null;const c=grade?gC(grade):'#6b6760';
  const dv=value==null||isNaN(value)?'N/A':typeof value==='number'?value.toFixed(unit==='%'?2:value>100?1:2):value;
  return(
    <div className={`grid grid-cols-12 gap-3 py-3 border-b border-stone-800 items-center ${highlight?'bg-amber-500/5':''}`}>
      <div className="col-span-5 text-sm text-stone-300" style={{fontFamily:'Fraunces,serif'}}>{label}</div>
      <div className="col-span-3 text-right text-stone-100" style={{fontFamily:'JetBrains Mono,monospace'}}>{dv}{unit}</div>
      <div className="col-span-2 text-right text-xs text-stone-500" style={{fontFamily:'JetBrains Mono,monospace'}}>
        {benchmark!=null?`vs ${typeof benchmark==='number'?benchmark.toFixed(1):benchmark}${unit}`:''}
