  const stockFactors=[
    {key:'valuation',icon:DollarSign,title:'Valuation',desc:'Price vs fundamentals',count:7},
    {key:'growth',icon:TrendingUp,title:'Growth',desc:'Top & bottom line trajectory',count:7},
    {key:'profitability',icon:Activity,title:'Profitability',desc:'Margins & capital efficiency',count:7},
    {key:'momentum',icon:Zap,title:'Momentum',desc:'Price performance',count:5},
    {key:'revisions',icon:Target,title:'Revisions',desc:'Analyst estimate changes',count:3},
  ];

