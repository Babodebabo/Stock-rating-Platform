const QUICK = ['AAPL','MSFT','NVDA','SCHD','JEPI','VOO','QQQ','ARCC','VTI','O'];

const App = () => {
  const [input,setInput]=useState('');
  const [ticker,setTicker]=useState(null);
  const [loading,setLoading]=useState(false);
  const [data,setData]=useState(null);
