            <p>Auto-detection determines whether a ticker is a stock or ETF before pulling the appropriate data set. Market Intelligence scans geopolitical and macro catalysts for forward-looking ideas, refreshed every 24 hours.</p>
          </div>
        </div>
      )}

      <main className="max-w-7xl mx-auto px-6 py-8">
        {/* SEARCH */}
        <div className="mb-6">
          <div className="flex gap-3 mb-4">
            <div className="flex-1 relative">
              <Search size={18} className="absolute left-4 top-1/2 -translate-y-1/2 text-stone-500"/>
              <input type="text" value={input} onChange={e=>setInput(e.target.value.toUpperCase())} onKeyDown={e=>e.key==='Enter'&&run(input)} placeholder="Enter any stock or ETF ticker..." className="w-full bg-stone-900 border border-stone-800 rounded-lg pl-12 pr-4 py-4 text-lg tracking-wider focus:outline-none focus:border-amber-500 transition" style={{fontFamily:'JetBrains Mono,monospace'}}/>
            </div>
            <button onClick={()=>run(input)} disabled={loading||!input} className="px-8 py-4 rounded-lg font-bold uppercase tracking-widest text-sm transition disabled:opacity-40" style={{background:'linear-gradient(135deg,#e0a94e,#c08a2e)',color:'#0c0a09',fontFamily:'JetBrains Mono,monospace'}}>{loading?<RefreshCw size={18} className="animate-spin"/>:'Analyze'}</button>
          </div>
          <div className="flex flex-wrap gap-2">
            <span className="text-xs uppercase tracking-widest text-stone-500 self-center mr-2" style={{fontFamily:'JetBrains Mono,monospace'}}>Quick:</span>
            {QUICK.map(s=><button key={s} onClick={()=>run(s)} className="px-3 py-1.5 text-xs bg-stone-900 hover:bg-stone-800 border border-stone-800 rounded transition" style={{fontFamily:'JetBrains Mono,monospace'}}>{s}</button>)}
          </div>
        </div>

        {/* MARKET INTELLIGENCE */}
        <div className="mb-6 bg-gradient-to-br from-stone-900/60 to-stone-950 border border-amber-900/30 rounded-lg overflow-hidden">
