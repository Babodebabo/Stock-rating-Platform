        {loading&&<div className="text-center py-20"><RefreshCw size={48} className="animate-spin mx-auto mb-4 text-amber-400"/><div className="text-lg text-stone-300">Detecting asset type and researching {ticker}...</div><div className="text-xs text-stone-500 mt-2" style={{fontFamily:'JetBrains Mono,monospace'}}>Pulling data from multiple sources. 30-60 seconds.</div></div>}

        {error&&<div className="bg-red-950/40 border border-red-900 rounded-lg p-6 flex items-start gap-3"><AlertTriangle className="text-red-400 flex-shrink-0 mt-0.5"/><div><div className="font-bold text-red-300">Analysis failed</div><div className="text-sm text-red-200 mt-1">{error}</div></div></div>}

        {data&&grades&&!loading&&(
