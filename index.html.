// ============================================================================
const computeEtfGrades = d => {
  if(!d) return null;
  // Cost & Structure
  const cs=[sL(d.cost?.expenseRatio,[0.06,0.15,0.35,0.60,0.90]),sH(d.cost?.aum,[50,20,5,1,0.2]),sL(d.cost?.spread,[0.02,0.05,0.10,0.20,0.50]),sL(d.cost?.trackingError,[0.05,0.15,0.30,0.60,1.0])];
  // Performance
  const rel1Y=(d.performance?.return1Y!=null&&d.performance?.benchReturn1Y!=null)?d.performance.return1Y-d.performance.benchReturn1Y:null;
  const rel3Y=(d.performance?.return3YAnn!=null&&d.performance?.benchReturn3YAnn!=null)?d.performance.return3YAnn-d.performance.benchReturn3YAnn:null;
  const pfs=[sH(d.performance?.return1Y,[25,12,5,0,-10]),sH(d.performance?.return3YAnn,[18,10,5,0,-5]),sH(d.performance?.return5YAnn,[16,10,6,2,-3]),sH(rel1Y,[5,2,0,-2,-5]),sH(rel3Y,[3,1,0,-1.5,-4])];
  // Risk
  const rks=[sH(d.risk?.sharpeRatio,[1.5,1.0,0.7,0.4,0.1]),sH(d.risk?.sortinoRatio,[2.0,1.3,0.8,0.4,0.1]),sL(d.risk?.maxDrawdown,[-5,-10,-18,-28,-40]),sL(d.risk?.stdDev,[8,12,16,22,30]),sL(d.risk?.beta,[0.6,0.8,1.0,1.2,1.5])];
  // Income
  const is=[sH(d.income?.distributionYield,[5,3.5,2.5,1.5,0.5]),sH(d.income?.yieldGrowth3Y,[8,5,2,0,-2]),sH(d.income?.yieldGrowth5Y,[7,4,2,0,-2]),sL(d.income?.yieldVolatility,[5,10,20,35,50])];
  // Holdings Quality
  const hs=[sH(d.holdings?.wtdRoe,[22,16,11,6,2]),sH(d.holdings?.wtdRoic,[18,13,9,5,1]),sH(d.holdings?.wtdFcfMargin,[18,12,7,3,0]),sL(d.holdings?.concentration,[25,35,45,60,75]),sH(d.holdings?.numHoldings==null?null:(d.holdings.numHoldings>=500?95:d.holdings.numHoldings>=200?85:d.holdings.numHoldings>=80?72:d.holdings.numHoldings>=30?58:45),[95,85,72,58,45])];
  const cS=avg(cs),pfS=avg(pfs),rkS=avg(rks),iS=avg(is),hS=avg(hs);
  const comp=avg([cS,pfS,rkS,iS,hS]);
  return{cost:{score:cS,grade:s2g(cS),ms:cs},performance:{score:pfS,grade:s2g(pfS),ms:pfs},risk:{score:rkS,grade:s2g(rkS),ms:rks},income:{score:iS,grade:s2g(iS),ms:is},holdings:{score:hS,grade:s2g(hS),ms:hs},composite:{score:comp,grade:s2g(comp),rating:cR(comp)}};
};

